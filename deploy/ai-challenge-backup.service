[Unit]
Description=Thử thách AI production backup
Wants=ai-challenge-api.service

[Service]
Type=oneshot
WorkingDirectory=/opt/ai-challenge-hub
EnvironmentFile=/etc/ai-challenge-hub.env
Environment=NODE_NO_WARNINGS=1
ExecStart=/usr/bin/node /opt/ai-challenge-hub/scripts/backup-production.mjs
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/ai-challenge-hub/storage

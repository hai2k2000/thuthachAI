[Unit]
Description=Thử thách AI submissions API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/ai-challenge-hub
EnvironmentFile=/etc/ai-challenge-hub.env
Environment=NODE_NO_WARNINGS=1
ExecStart=/usr/bin/node /opt/ai-challenge-hub/server/index.mjs
Restart=always
RestartSec=5
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/ai-challenge-hub/storage

[Install]
WantedBy=multi-user.target
